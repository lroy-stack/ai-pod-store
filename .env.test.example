# ====================================================================
# Test Credentials — NEVER commit real values
# ====================================================================
#
# Copy to .env.test and fill in credentials for YOUR test environment.
# .env.test is gitignored — it must never be committed.
#
#   cp .env.test.example .env.test
#

# ── Frontend E2E test user ─────────────────────────────────────────
# A real customer account in your Supabase project for testing
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# ── Admin E2E test user ────────────────────────────────────────────
# Your admin account (created via scripts/create-secure-admin.mjs)
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# ── Test environment URLs ──────────────────────────────────────────
TEST_BASE_URL=http://localhost:3000
TEST_ADMIN_URL=http://localhost:3001
