# syntax=docker/dockerfile:1

# =============================================================================
# Multi-stage Dockerfile for Next.js standalone production build
# Base: node:22-alpine
# Stages: deps -> builder -> runner
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: Install dependencies
# ---------------------------------------------------------------------------
FROM node:22-alpine AS deps

WORKDIR /app

# Native build tools for canvas (node-gyp needs python3, make, g++)
RUN apk add --no-cache python3 make g++ pkgconf cairo-dev pango-dev jpeg-dev giflib-dev

# Copy only package manifests for better layer caching
COPY package.json package-lock.json ./

# Install dependencies (npm install tolerates minor peer dep mismatches)
# PUPPETEER_SKIP_DOWNLOAD: puppeteer is a devDep used only for testing,
# skip Chrome download to avoid failure on Alpine
ENV PUPPETEER_SKIP_DOWNLOAD=true
RUN npm install --ignore-scripts=false

# ---------------------------------------------------------------------------
# Stage 2: Build the application
# ---------------------------------------------------------------------------
FROM node:22-alpine AS builder

WORKDIR /app

# Runtime libs for canvas native module (loaded during `next build`)
RUN apk add --no-cache cairo pango jpeg giflib

# Disable Next.js telemetry during build
ENV NEXT_TELEMETRY_DISABLED=1

# NEXT_PUBLIC vars are inlined by webpack into client-side bundles at build time.
# For production: pass real values via --build-arg.
# For local builds: defaults allow the build to succeed.
ARG NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-anon-key
ARG NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
ARG NEXT_PUBLIC_BASE_URL=http://localhost:3000
ARG NEXT_PUBLIC_SITE_NAME=YOUR_BRAND_NAME
ARG NEXT_PUBLIC_SITE_TAGLINE=Wear what you mean
ARG NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/yourbrand
ARG NEXT_PUBLIC_SOCIAL_TWITTER=https://twitter.com/yourbrand
ARG NEXT_PUBLIC_SOCIAL_FACEBOOK=https://facebook.com/yourbrand
ARG NEXT_PUBLIC_TURNSTILE_SITE_KEY=
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=$NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
ENV NEXT_PUBLIC_BASE_URL=$NEXT_PUBLIC_BASE_URL
ENV NEXT_PUBLIC_SITE_NAME=$NEXT_PUBLIC_SITE_NAME
ENV NEXT_PUBLIC_SITE_TAGLINE=$NEXT_PUBLIC_SITE_TAGLINE
ENV NEXT_PUBLIC_SOCIAL_INSTAGRAM=$NEXT_PUBLIC_SOCIAL_INSTAGRAM
ENV NEXT_PUBLIC_SOCIAL_TWITTER=$NEXT_PUBLIC_SOCIAL_TWITTER
ENV NEXT_PUBLIC_SOCIAL_FACEBOOK=$NEXT_PUBLIC_SOCIAL_FACEBOOK
ENV NEXT_PUBLIC_TURNSTILE_SITE_KEY=$NEXT_PUBLIC_TURNSTILE_SITE_KEY

# Server-side vars needed only at build time — some API routes create
# Supabase clients at module scope (imported during `next build`).
# These do NOT leak to the production image (runner stage is separate).
# SUPABASE_SERVICE_KEY is injected via BuildKit secret mount (never stored
# in image layers or docker history). Fallback to placeholder for local builds.
# SUPABASE_URL is not sensitive but kept as ARG for consistency.
ARG SUPABASE_URL=https://placeholder.supabase.co
ENV SUPABASE_URL=$SUPABASE_URL

# Copy node_modules from deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy the rest of the application source
COPY . .

# Build the Next.js application.
# --mount=type=secret keeps SUPABASE_SERVICE_KEY out of image layers/history.
RUN --mount=type=secret,id=supabase_service_key \
    SUPABASE_SERVICE_KEY=$(cat /run/secrets/supabase_service_key 2>/dev/null || echo 'placeholder') \
    npm run build

# ---------------------------------------------------------------------------
# Stage 3: Production runner
# ---------------------------------------------------------------------------
FROM node:22-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV HOSTNAME="0.0.0.0"
ENV PORT=3000

# Install curl for healthcheck
RUN apk add --no-cache curl

# Create non-root user
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Copy public assets
COPY --from=builder /app/public ./public

# Copy the standalone build output
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./

# Copy static assets generated by the build
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

# Switch to non-root user
USER nextjs

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD curl -f http://localhost:3000/api/health || exit 1

CMD ["node", "server.js"]
