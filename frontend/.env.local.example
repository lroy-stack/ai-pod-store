# Frontend Environment Variables
# Copy this to .env.local and fill in your values

# ============================================
# PUBLIC VARIABLES (exposed to browser)
# ============================================

# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe (public)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Base URL (for absolute URLs in emails, OG tags, etc.)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Feature flags
NEXT_PUBLIC_ENABLE_VOICE_INPUT=true
NEXT_PUBLIC_ENABLE_IMAGE_UPLOAD=true
NEXT_PUBLIC_ENABLE_PWA=true

# ============================================
# SERVER-SIDE VARIABLES (never exposed)
# ============================================

# Supabase (server)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Stripe (server)
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PREMIUM_PRICE_ID=               # [REQUIRED] Stripe Price ID for Premium plan (price_xxx)

# Printify
PRINTIFY_API_TOKEN=your-printify-api-token
PRINTIFY_SHOP_ID=your-shop-id
PRINTIFY_WEBHOOK_SECRET=your-printify-webhook-secret

# AI Services
FAL_KEY=your-fal-ai-key
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key

# Email
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Infrastructure
REDIS_URL=redis://localhost:6379
REMBG_URL=http://localhost:7000

# Internationalization
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,es,de
