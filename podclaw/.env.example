# PodClaw — Environment Variables Template
# Copy to .env and fill in real values.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...

# Printify
PRINTIFY_API_TOKEN=your-printify-jwt
PRINTIFY_SHOP_ID=your-shop-id

# Google AI (Gemini)
GEMINI_API_KEY=your-gemini-key

# fal.ai (Design generation / background removal)
FAL_KEY=your-fal-key

# Resend (Email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_WEBHOOK_SECRET=whsec_...

# rembg sidecar (local background removal)
REMBG_URL=http://localhost:8090

# Bridge auth (generate with: openssl rand -hex 32)
PODCLAW_BRIDGE_AUTH_TOKEN=
PODCLAW_BRIDGE_AUTH_ENABLED=false
