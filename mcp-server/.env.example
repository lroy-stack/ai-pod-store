# MCP Server Configuration

# Port to listen on (default: 8002)
PORT=8002

# Base URL for OAuth callbacks and metadata (default: http://localhost:8002)
MCP_BASE_URL=http://localhost:8002

# Comma-separated list of allowed CORS origins
# Default: https://claude.ai,https://chatgpt.com,http://localhost:3000
# Add additional origins for production (e.g., your deployed frontend URL)
MCP_CORS_ORIGINS=https://claude.ai,https://chatgpt.com,http://localhost:3000

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Redis Configuration (optional - graceful fallback if unavailable)
REDIS_URL=redis://localhost:6379

# JWT Secret for signing access tokens (use a strong random string, min 32 chars)
MCP_JWT_SECRET=your-jwt-secret-here

# Shared secret for OAuth consent approval bridge (frontend → MCP server, min 32 chars)
# Generate: openssl rand -hex 32
MCP_APPROVE_SECRET=your-approve-secret-here

# Trusted proxy IPs for X-Forwarded-For (comma-separated, default: 127.0.0.1,::1)
# TRUSTED_PROXY_IPS=127.0.0.1,::1

# Enable test auth auto-approve (NEVER set in production)
# MCP_ENABLE_TEST_AUTH=true
