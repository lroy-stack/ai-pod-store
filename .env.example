# ====================================================================
# POD Platform — Environment Variables (Centralized)
# ====================================================================
#
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# Generate secrets:
#   openssl rand -hex 32
#
# Docker Compose auto-loads .env from the project root.
# Quick start:
#   ./start.sh --private

# -------------------------------------------------------------------
# SERVICE TOGGLES — activate/deactivate service groups
# -------------------------------------------------------------------
ENABLE_MONITORING=false          # true → prometheus, grafana, loki, promtail
ENABLE_SUPABASE=false            # true → Supabase self-hosted (see section below)
# ENABLE_STUDIO=false            # (future) true → Supabase Studio dashboard
ENVIRONMENT=private              # private | public

# -------------------------------------------------------------------
# [SUPABASE SELF-HOSTED] — Only needed when ENABLE_SUPABASE=true
# These variables configure the local Supabase stack (13 services).
# When ENABLE_SUPABASE=false, the stack uses Supabase Cloud vars above.
# -------------------------------------------------------------------

# Database
POSTGRES_PASSWORD=               # [REQUIRED] openssl rand -hex 32 (NO @ or % chars!)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# JWT — MUST be identical across Kong, GoTrue, PostgREST, Realtime, Storage
JWT_SECRET=                      # [REQUIRED] openssl rand -hex 32
ANON_KEY=                        # [REQUIRED] Generate: supabase.com/docs/guides/self-hosting#api-keys
SERVICE_ROLE_KEY=                # [REQUIRED] Generate: supabase.com/docs/guides/self-hosting#api-keys
JWT_EXPIRY=3600

# Encryption keys
SECRET_KEY_BASE=                 # [REQUIRED] 64-char hex (Realtime Phoenix secret)
VAULT_ENC_KEY=                   # [REQUIRED] openssl rand -hex 16 (Vault encryption)
PG_META_CRYPTO_KEY=              # [REQUIRED] openssl rand -hex 16 (pg-meta encryption)

# Dashboard (Studio, optional)
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=              # [REQUIRED] openssl rand -hex 24

# Analytics (Logflare — required, dependency chain)
LOGFLARE_PUBLIC_ACCESS_TOKEN=    # [REQUIRED] openssl rand -hex 16
LOGFLARE_PRIVATE_ACCESS_TOKEN=   # [REQUIRED] openssl rand -hex 16

# Public URLs (how browsers reach Supabase)
SUPABASE_PUBLIC_URL=             # https://api.yourdomain.com (prod) or http://localhost:8000 (local)
API_EXTERNAL_URL=                # Same as SUPABASE_PUBLIC_URL
SITE_URL=                        # https://yourdomain.com (prod) or http://localhost:3000 (local)

# SMTP — GoTrue email delivery (reuse Resend credentials)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=                       # Same as RESEND_API_KEY
SMTP_ADMIN_EMAIL=                # Same as ADMIN_EMAIL
SMTP_SENDER_NAME=YOUR_BRAND_NAME

# Auth settings
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
DISABLE_SIGNUP=false
ADDITIONAL_REDIRECT_URLS=

# GoTrue mailer URL paths
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

# PostgREST
PGRST_DB_SCHEMAS=public,storage,graphql_public

# Kong ports (override in private/public overlays)
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# Studio (optional, enable with --with-studio)
STUDIO_DEFAULT_ORGANIZATION=YOUR_BRAND_NAME
STUDIO_DEFAULT_PROJECT=pod-platform

# -------------------------------------------------------------------
# [REQUIRED] Supabase (Cloud)
# Used by: frontend, podclaw, mcp-server
# -------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# -------------------------------------------------------------------
# [REQUIRED] NEXT_PUBLIC — Build-time frontend/admin vars
# Baked into JS bundles by webpack at `docker compose build` time.
# Used by: frontend (build), admin (build)
# -------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# -------------------------------------------------------------------
# [REQUIRED] Stripe
# Used by: frontend (payments + webhooks), podclaw (refunds)
# -------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PREMIUM_PRICE_ID=

# -------------------------------------------------------------------
# [REQUIRED] Printify
# Used by: podclaw (product management)
# -------------------------------------------------------------------
PRINTIFY_API_TOKEN=your-printify-jwt
PRINTIFY_SHOP_ID=your-shop-id

# -------------------------------------------------------------------
# [REQUIRED] AI Services
# Used by: podclaw (all agents)
# -------------------------------------------------------------------
# ANTHROPIC_API_KEY not needed — PodClaw uses Claude Agent SDK OAuth (Max Plan)
# Authentication is handled via `claude auth login` (tokens stored locally)
FAL_KEY=your-fal-key
GEMINI_API_KEY=your-gemini-key

# -------------------------------------------------------------------
# [REQUIRED] Email (Resend)
# Used by: frontend (transactional), podclaw (marketing/newsletters)
# -------------------------------------------------------------------
RESEND_API_KEY=re_placeholder
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_WEBHOOK_SECRET=whsec_placeholder

# -------------------------------------------------------------------
# [REQUIRED] Redis
# Used by: frontend, podclaw, mcp-server (session cache, rate limiting)
# Generate with: openssl rand -hex 32
# -------------------------------------------------------------------
REDIS_PASSWORD=change-me-generate-with-openssl-rand-hex-32

# -------------------------------------------------------------------
# [REQUIRED] Bridge Authentication
# Token shared between admin panel and PodClaw bridge API.
# Used by: admin (as client), podclaw (as server)
# Generate with: openssl rand -hex 32
# -------------------------------------------------------------------
# PRODUCTION: Generate with 'openssl rand -hex 32'. DO NOT use placeholder value.
PODCLAW_BRIDGE_AUTH_TOKEN=change-me-generate-with-openssl-rand-hex-32

# -------------------------------------------------------------------
# [REQUIRED] Admin Panel Session Encryption
# Used by: admin (iron-session cookie encryption)
# Generate with: openssl rand -hex 32
# -------------------------------------------------------------------
SESSION_SECRET=generate-with-openssl-rand-hex-32

# -------------------------------------------------------------------
# [REQUIRED] MCP Server JWT Secret
# Used by: mcp-server (OAuth 2.1 token signing/validation)
# Generate with: openssl rand -hex 32
# -------------------------------------------------------------------
MCP_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# -------------------------------------------------------------------
# [REQUIRED] MCP OAuth Approval Secret
# Used by: mcp-server + frontend (shared secret for /oauth/approve bridge)
# Generate with: openssl rand -hex 32
# -------------------------------------------------------------------
MCP_APPROVE_SECRET=change-me-generate-with-openssl-rand-hex-32

# -------------------------------------------------------------------
# [OPTIONAL] MCP Registered Clients (JSON)
# Used by: mcp-server (additional OAuth client registrations beyond built-in)
# Format: {"client-id": {"name":"App Name","redirect_uris":["https://..."],"scopes":["read","write"],"type":"public"}}
# -------------------------------------------------------------------
MCP_REGISTERED_CLIENTS=

# -------------------------------------------------------------------
# [OPTIONAL] Telegram & WhatsApp Notifications
# Used by: podclaw
# -------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
PODCLAW_ADMIN_TELEGRAM_CHAT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# -------------------------------------------------------------------
# [OPTIONAL] Cloudflare Turnstile (CAPTCHA)
# Used by: frontend
# -------------------------------------------------------------------
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# -------------------------------------------------------------------
# [REQUIRED] Cron Secret
# Used by: frontend (cron endpoint auth). Generate with: openssl rand -hex 32
# -------------------------------------------------------------------
CRON_SECRET=change-me-generate-with-openssl-rand-hex-32
# Used by: admin (themes activate) → frontend (revalidate/theme). Shared secret, NOT a Supabase key.
REVALIDATION_SECRET=change-me-generate-with-openssl-rand-hex-32

# -------------------------------------------------------------------
# [OPTIONAL] Webhook Secrets
# Used by: frontend (webhook signature verification)
# -------------------------------------------------------------------
PRINTIFY_WEBHOOK_SECRET=
PRINTFUL_WEBHOOK_SECRET=

# -------------------------------------------------------------------
# [OPTIONAL] Printful (multi-provider migration)
# Used by: frontend (catalog sync, order management)
# -------------------------------------------------------------------
PRINTFUL_API_TOKEN=
PRINTFUL_STORE_ID=

# -------------------------------------------------------------------
# [OPTIONAL] Gemini (AI SDK — frontend chat)
# Used by: frontend
# -------------------------------------------------------------------
GOOGLE_GENERATIVE_AI_API_KEY=

# -------------------------------------------------------------------
# [OPTIONAL] i18n
# Used by: frontend
# -------------------------------------------------------------------
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,es,de

# -------------------------------------------------------------------
# [REQUIRED] White-Label Brand Configuration
# ─────────────────────────────────────────────────────────────────────
# These variables control ALL branding in the platform. No code changes
# are needed — set these once and the entire stack uses your brand.
#
# NEXT_PUBLIC_ variables are baked into JS bundles at build time
# (docker compose build). Runtime variables are read at request time.
# -------------------------------------------------------------------

# ── Core brand — SINGLE SOURCE OF TRUTH ───────────────────────────
# BRAND_NAME is used by PodClaw agents when creating products (e.g. brand field in Printify).
# It falls back to NEXT_PUBLIC_SITE_NAME if not set.
BRAND_NAME=My Store                        # [REQUIRED] Brand name used by agents + email templates

# ── Core brand (build-time, NEXT_PUBLIC_) ──────────────────────────
NEXT_PUBLIC_SITE_NAME=My POD Store        # Store display name (appears everywhere)
NEXT_PUBLIC_SITE_TAGLINE=Custom products, made for you
NEXT_PUBLIC_BASE_URL=https://yourdomain.com   # Your production URL (no trailing slash)
NEXT_PUBLIC_MCP_BASE_URL=https://mcp.yourdomain.com  # MCP server URL for AI integrations

# Store description (used in meta tags, per locale)
# NEXT_PUBLIC_SITE_DESCRIPTION_EN=Your store description in English
# NEXT_PUBLIC_SITE_DESCRIPTION_ES=Descripción de tu tienda en español
# NEXT_PUBLIC_SITE_DESCRIPTION_DE=Beschreibung deines Shops auf Deutsch

# ── Social links (optional, leave empty to hide social icons) ──────
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_TWITTER=
NEXT_PUBLIC_SOCIAL_FACEBOOK=

# ── Contact emails (runtime) ───────────────────────────────────────
STORE_CONTACT_EMAIL=hello@yourdomain.com
STORE_SUPPORT_EMAIL=support@yourdomain.com
STORE_LEGAL_EMAIL=legal@yourdomain.com
STORE_PRIVACY_EMAIL=privacy@yourdomain.com
STORE_NOREPLY_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# ── Company legal info (runtime, used in emails + legal pages) ─────
STORE_COMPANY_NAME=Your Company Name
STORE_COMPANY_ADDRESS=Your Company Address, City, Country
STORE_COMPANY_COUNTRY=DE        # ISO 3166-1 alpha-2 country code
STORE_TAX_ID=                   # Optional VAT/tax ID number
STORE_DOMAIN=yourdomain.com     # Your domain (without https://)
STORE_USER_AGENT=POD-Platform/1.0

# ── API base URL (for CSP headers when using self-hosted Supabase) ─
# Set this to your Supabase API URL (e.g., https://api.yourdomain.com)
# Leave empty if using Supabase Cloud (*.supabase.co is already in CSP)
NEXT_PUBLIC_API_BASE_URL=

# ── Email logo URLs (for transactional emails) ─────────────────────
# Upload your logo to Supabase Storage or any CDN, then set these.
# Must be public HTTPS URLs — emails render in Gmail/Outlook externally.
# If empty, the system uses the default path in your Supabase storage bucket:
#   /storage/v1/object/public/marketing/email/logo-mark-white.png
#   /storage/v1/object/public/marketing/email/logo-wordmark-white.png
EMAIL_LOGO_URL=
EMAIL_WORDMARK_URL=

# ── Store currency ─────────────────────────────────────────────────
STORE_CURRENCY=EUR    # ISO 4217 currency code

# ── Legacy aliases (podclaw reads these) ──────────────────────────
STORE_PHYSICAL_ADDRESS=Your Company Address, City, Country
STORE_SENDER_NAME=My POD Store

# -------------------------------------------------------------------
# [REQUIRED for prod] Domain (Caddy auto-HTTPS via Let's Encrypt)
# Leave empty for local dev (defaults to http://localhost).
# -------------------------------------------------------------------
DOMAIN=

# -------------------------------------------------------------------
# [REQUIRED] Grafana Admin Password
# Change from default before deploying! Default 'admin' is insecure.
# Used by: grafana (dashboard auth)
# Generate with: openssl rand -hex 24
# -------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# -------------------------------------------------------------------
# [OPTIONAL] Monitoring Stack
# Set to true to enable Prometheus, Grafana, and Loki services
# Used by: docker-compose.yml (start.sh Phase 4)
# -------------------------------------------------------------------
ENABLE_MONITORING=false

# -------------------------------------------------------------------
# [OPTIONAL] PodClaw Tuning (defaults are sensible — see podclaw/config.py)
# -------------------------------------------------------------------
# PODCLAW_DAILY_BUDGET=5.0
# PODCLAW_GLOBAL_DAILY_SPEND_LIMIT=30.0
# PODCLAW_RESEARCH_MODEL=claude-haiku-4-5-20251001
# PODCLAW_COMPLEX_MODEL=claude-sonnet-4-5-20250929
# PODCLAW_MAX_ACTIONS_PER_CYCLE=50
# PODCLAW_MAX_TURNS_PER_AGENT=200
# PODCLAW_JSON_LOGS=true
# PODCLAW_HEARTBEAT_ENABLED=true
# PODCLAW_HEARTBEAT_INTERVAL=30
# PODCLAW_SOUL_EVOLUTION_ENABLED=true
