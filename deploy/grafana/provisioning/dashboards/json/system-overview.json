{
  "dashboard": {
    "title": "System Overview",
    "tags": ["system", "infrastructure"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Service Uptime",
        "type": "stat",
        "targets": [
          {
            "expr": "frontend_uptime_seconds",
            "legendFormat": "Frontend",
            "refId": "A"
          },
          {
            "expr": "admin_uptime_seconds",
            "legendFormat": "Admin",
            "refId": "B"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "orientation": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 60, "color": "yellow"},
                {"value": 300, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Memory Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "frontend_memory_usage_bytes{type=\"heap_used\"}",
            "legendFormat": "Frontend Heap",
            "refId": "A"
          },
          {
            "expr": "admin_memory_usage_bytes{type=\"heap_used\"}",
            "legendFormat": "Admin Heap",
            "refId": "B"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": {
              "fillOpacity": 10,
              "lineWidth": 2
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Heap Usage Ratio",
        "type": "gauge",
        "targets": [
          {
            "expr": "frontend_heap_usage_ratio",
            "legendFormat": "Frontend",
            "refId": "A"
          },
          {
            "expr": "admin_heap_usage_ratio",
            "legendFormat": "Admin",
            "refId": "B"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "options": {
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.7, "color": "yellow"},
                {"value": 0.9, "color": "red"}
              ]
            }
          }
        }
      }
    ]
  },
  "overwrite": true
}
