{
  "dashboard": {
    "title": "Ecommerce Metrics",
    "tags": ["ecommerce", "business", "revenue"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "5m",
    "panels": [
      {
        "id": 1,
        "title": "Frontend Service Health",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"frontend\"}",
            "legendFormat": "Storefront",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
        "options": {
          "colorMode": "background",
          "graphMode": "none"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 1, "color": "green"}
              ]
            },
            "mappings": [
              {"type": "value", "value": "0", "text": "OFFLINE"},
              {"type": "value", "value": "1", "text": "ONLINE"}
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "Frontend Memory Trend",
        "type": "timeseries",
        "targets": [
          {
            "expr": "frontend_memory_usage_bytes{type=\"heap_used\"}",
            "legendFormat": "Heap Used",
            "refId": "A"
          },
          {
            "expr": "frontend_memory_usage_bytes{type=\"heap_total\"}",
            "legendFormat": "Heap Total",
            "refId": "B"
          }
        ],
        "gridPos": {"h": 8, "w": 16, "x": 8, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": {
              "fillOpacity": 10
            }
          }
        }
      }
    ]
  },
  "overwrite": true
}
